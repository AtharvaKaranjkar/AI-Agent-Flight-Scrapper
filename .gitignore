# =============================================
# Ignore sensitive data and temporary files
# =============================================

# API keys & secrets (NEVER commit these!)
config.py

# Debug images (large and not needed in repo)
debug_*.png
debug_*.jpg
debug_*.jpeg
debug_*.bmp

# Final screenshots (also large and may contain personal info)
MMT_*.png
MMT_*.jpg
screenshot_*.png

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Virtual environment
venv/
env/
ENV/
.venv

# Environment variables
.env
.env.local

# Logs
*.log

# IDE settings (optional)
.vscode/
.idea/
*.swp
*.swo

# OS junk files
.DS_Store
Thumbs.db
